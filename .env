INTELX_APPLICATION=Breachcord # Required as it is requested by IntelX. Failing to self-identify may result in revoking API key/your license and/or banning your software. (by default Breachcord)
INTELX_TOKEN= # API key in format of 00000000-0000-0000-0000-000000000000. You can get your API key from https://intelx.io/account?tab=developer
INTELX_PORTAL=https://free.intelx.io/intelligent/search # Do not overwrite unless you have valid IntelX license. You can check your API endpoint anytime in https://intelx.io/account?tab=developer


HIBP_TOKEN=00000000000000000000000000000007 # To do searches/lookups, you need paid subscription (https://haveibeenpwned.com/Subscription) | Test API key is available at (https://haveibeenpwned.com/API/v3#TestAPIKey)
HIBP_APPLICATION=Breachcord_Developments # The user agent should accurately describe the nature of the API consumer such that it can be clearly identified in the request. Not doing so may result in the request being blocked (as stated in the 										     HaveIBeenPwned API documentation: haveibeenpwned.com/API/v3#UserAgent)


SCAMALYTICS_API_KEY= # Get your API key from https://scamalytics.com/ip/api/pricing
SCAMALYTICS_USERNAME= # Your Scamalytics Username


BOT_NAME=Breachcord # The 'name' variable used in embeds
BOT_ICON=https://media.discordapp.net/attachments/1427359467485270038/1438913004094619820/Breachcord-ProfilePicture.png?ex=69189ba9&is=69174a29&hm=213a0e154b14ab7622c370eaa3b24e1dd5a0cc904a29354fe492bd33ea99ab31&=&format=webp&quality=lossless
BOT_TOKEN= # Your Discord Bot token can be obtained from the Discord Developer Portal at https://discord.com/developers/applications.
BOT_WATERMARK=TRUE # by default True, small watermark consisting of link to the original Github repository.